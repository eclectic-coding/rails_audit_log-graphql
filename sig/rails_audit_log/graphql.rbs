module RailsAuditLog
  module Graphql
    VERSION: String

    module Types
      class BaseObject < GraphQL::Schema::Object
      end

      class BaseSubscription < GraphQL::Schema::Subscription
      end

      class DiffType < BaseObject
        def attribute: () -> String
        def from: () -> untyped
        def to: () -> untyped
      end

      class ActorType < BaseObject
        def id: () -> String
        def type_name: () -> String
      end

      class AuditedResourceType < BaseObject
        def id: () -> String
        def type_name: () -> String
      end

      class AuditLogEntryType < BaseObject
        def actor: () -> Hash[Symbol, untyped]?
        def audited_resource: () -> Hash[Symbol, untyped]
        def diff: () -> Array[Hash[Symbol, untyped]]?
      end

      class SortDirectionEnum < GraphQL::Schema::Enum
      end

      class AuditLogEntrySortFieldEnum < GraphQL::Schema::Enum
      end
    end

    module InputObjects
      class AuditLogEntrySortInput < GraphQL::Schema::InputObject
        def field: () -> Symbol
        def direction: () -> Symbol
      end
    end

    module Generators
      module Graphql
        class InstallGenerator < ::Rails::Generators::Base
          def inject_mixin: () -> void
          def print_next_steps: () -> void
        end
      end
    end

    module Subscriptions
      class AuditLogEntryCreated < Types::BaseSubscription
        def subscribe: (?item_type: String?, ?item_id: String?, ?actor_id: String?) -> :no_response
        def update: (?item_type: String?, ?item_id: String?, ?actor_id: String?) -> untyped
      end

      module AuditLogSubscriptionsMixin
        def self.included: (untyped base) -> void
      end

      class Broadcaster
        def initialize: (schema: untyped) -> void
        def start: () -> void
        def stop: () -> void
        def broadcast: (untyped entry) -> void
      end
    end

    module Queries
      module AuditLogEntriesQueryMixin
        def self.included: (untyped base) -> void

        def resolve_audit_log_entry: (id: String) -> untyped

        def resolve_audit_log_entries: (
          ?event: String?,
          ?item_type: String?,
          ?item_id: String?,
          ?actor_id: String?,
          ?since: Time?,
          ?until_time: Time?,
          ?touching: String?,
          ?order_by: InputObjects::AuditLogEntrySortInput?,
          ?page: Integer,
          ?per_page: Integer
        ) -> untyped

        def resolve_audit_log_entries_connection: (
          ?event: String?,
          ?item_type: String?,
          ?item_id: String?,
          ?actor_id: String?,
          ?since: Time?,
          ?until_time: Time?,
          ?touching: String?,
          ?order_by: InputObjects::AuditLogEntrySortInput?
        ) -> untyped

        private

        def build_scope: (
          ?event: String?,
          ?item_type: String?,
          ?item_id: String?,
          ?actor_id: String?,
          ?since: Time?,
          ?until_time: Time?,
          ?touching: String?,
          ?order_by: InputObjects::AuditLogEntrySortInput?
        ) -> untyped

        def check_authentication!: () -> void
      end
    end
  end
end